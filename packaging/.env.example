# packaging/make_exe.py 配置
# 复制此文件为 .env 并填入你的配置

# Inno Setup 6 编译器路径
# 留空则自动搜索常见安装位置（不支持 Inno Setup 5）
ISCC_PATH=

# 【必填】原版游戏文件夹路径，用于制作含游戏的完整安装包
ORIGINAL_GAME_FOLDER=

# 游戏版本号覆盖（留空则从 localization/localization_version.json 自动读取）
GAME_VERSION=

# 汉化版本号覆盖（留空则从 localization/localization_version.json 自动读取）
APP_VERSION=

# 各 git 分支对应的变体名（安装包名称后缀）
BRANCH_VARIANT_master=(黑体版)
BRANCH_VARIANT_font-simsong=(宋体版)
BRANCH_VARIANT_font-zongyi=(综艺体版)
